{
  "name": "parkingpage-comingsoon",
  "private": true,
  "version": "0.1.0",
  "description": "A drop-in coming soon page template with an interactive WebGL background, physics typography, and an email waitlist.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Simon/parkingpage-comingsoon.git"
  },
  "bugs": {
    "url": "https://github.com/One-Simon/parkingpage-comingsoon/issues"
  },
  "homepage": "https://github.com/One-Simon/parkingpage-comingsoon#readme",
  "keywords": [
    "coming-soon",
    "landing-page",
    "static-site",
    "vite",
    "pixi",
    "matter-js",
    "waitlist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test:smoke": "playwright test",
    "format": "prettier -c src tests playwright.config.ts vite.config.ts",
    "format:fix": "prettier -w src tests playwright.config.ts vite.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/matter-js": "^0.20.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "matter-js": "^0.20.0",
    "pixi.js": "^8.19.0"
  },
  "engines": {
    "node": ">=24.16.0 <25"
  }
}
